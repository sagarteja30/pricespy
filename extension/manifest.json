{
  "manifest_version": 3,
  "name": "PriceSpy — AI Price Predictor",
  "version": "1.0",
  "description": "Know if prices will rise or fall before you buy",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://www.amazon.in/*",
    "https://www.flipkart.com/*",
    "http://127.0.0.1/*"
  ],
  "content_scripts": [{
    "matches": [
      "https://www.amazon.in/*",
      "https://www.flipkart.com/*"
    ],
    "js": ["content.js"]
  }],
  "action": {
    "default_popup": "popup.html"
  }
}
