{
  "manifest_version": 3,
  "name": "PriceSpy — AI Price Predictor",
  "version": "1.1",
  "description": "Know if prices will rise or fall before you buy",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://www.amazon.in/*",
    "https://www.amazon.com/*",
    "https://www.flipkart.com/*",
    "https://*.railway.app/*",
    "https://*.render.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.in/*",
        "*://*.amazon.com/*",
        "*://*.flipkart.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "PriceSpy AI",
    "default_popup": "popup.html"
  }
}
